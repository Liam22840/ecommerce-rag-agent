# Chat model — Doubao Seed 2.0 Lite on Volcengine Ark.
# Use the model name for the public pool, or set ARK_CHAT_MODEL to your own endpoint id (ep-...)
# to call a low-latency / TPM-reserved 接入点. CHAT_DISABLE_THINKING turns off the model's
# deep-thinking mode (it's a reasoning model that defaults it on, adding several seconds per reply).
ARK_CHAT_API_KEY=
ARK_CHAT_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_CHAT_MODEL=doubao-seed-2-0-lite-260428
CHAT_DISABLE_THINKING=true

ARK_EMBEDDING_API_KEY=
ARK_EMBEDDING_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_EMBEDDING_MODEL=doubao-embedding-vision-251215

ENABLE_VECTOR_SEARCH=true
ENABLE_LLM=true
