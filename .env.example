# 对话模型。默认使用 Gemini Flash-Lite 的 OpenAI 兼容接口；也兼容 ARK_CHAT_* 变量名。
CHAT_API_KEY=
CHAT_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
CHAT_MODEL=gemini-3.1-flash-lite
# ARK_CHAT_API_KEY=
# ARK_CHAT_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# ARK_CHAT_MODEL=doubao-seed-2-0-lite

# 向量模型。data/milvus.db 按这个模型生成，线上查询必须使用同一个向量空间。
ARK_EMBEDDING_API_KEY=
ARK_EMBEDDING_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_EMBEDDING_MODEL=doubao-embedding-vision-251215

# 语音播报。TTS_API_KEY/GEMINI_API_KEY 二选一；不配置时 /api/tts 返回 503，iOS 会降级到系统语音。
ENABLE_TTS=true
TTS_API_KEY=
# GEMINI_API_KEY=
TTS_BASE_URL=https://generativelanguage.googleapis.com/v1beta
TTS_MODEL=gemini-3.1-flash-tts-preview
TTS_VOICE=Sulafat
TTS_TIMEOUT_SECONDS=30

ENABLE_VECTOR_SEARCH=true
ENABLE_LLM=true
ENABLE_LLM_INTENT=true
ENABLE_QUERY_CACHE=true
ENABLE_FILTER_CACHE=true
