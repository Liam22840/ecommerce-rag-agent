# Chat model — Gemini Flash-Lite via its OpenAI-compatible endpoint (fast, strong Chinese).
ARK_CHAT_API_KEY=
ARK_CHAT_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
ARK_CHAT_MODEL=gemini-3.1-flash-lite

# Embedding model — Doubao on Volcengine Ark. Keep this model: milvus.db was built in this
# embedding space, so query vectors must come from the same model or semantic search breaks.
ARK_EMBEDDING_API_KEY=
ARK_EMBEDDING_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_EMBEDDING_MODEL=doubao-embedding-vision-251215

ENABLE_VECTOR_SEARCH=true
ENABLE_LLM=true
