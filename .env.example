# Chat model — Doubao Seed 1.6 Flash on Volcengine Ark (low-latency SKU; activate it in the
# console first). CHAT_DISABLE_THINKING turns off deep-thinking (the model defaults it on, which
# adds reasoning tokens and several seconds per reply); off, replies come back in a few seconds.
ARK_CHAT_API_KEY=
ARK_CHAT_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_CHAT_MODEL=doubao-seed-1-6-flash-250828
CHAT_DISABLE_THINKING=true

ARK_EMBEDDING_API_KEY=
ARK_EMBEDDING_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_EMBEDDING_MODEL=doubao-embedding-vision-251215

ENABLE_VECTOR_SEARCH=true
ENABLE_LLM=true
