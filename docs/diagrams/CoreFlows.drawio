        <mxCell id="select_step" value="步骤 2：选择候选&#xa;从真实商品卡中按价格/相关度选择" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=13" vertex="1" parent="1">
