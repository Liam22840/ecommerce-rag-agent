        </mxCell>
        <mxCell id="compare_step" value="步骤 3：对比决策&#xa;复用对比模块选出赢家" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=13" vertex="1" parent="1">
          <mxGeometry x="700" y="330" width="210" height="75" as="geometry"/>
        </mxCell>
        <mxCell id="cart_step" value="步骤 4：购物车动作&#xa;加购 / 改数量 / 结算" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=13" vertex="1" parent="1">
