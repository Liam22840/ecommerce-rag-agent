        <mxCell id="request" value="复合请求&#xa;推荐、筛选、对比、加购、结算" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=14;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="70" y="120" width="180" height="80" as="geometry"/>
